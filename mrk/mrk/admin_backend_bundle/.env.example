# Firebase Admin (required)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# Admin auth (required)
ADMIN_SECRET=
ADMIN_SECRET_SALT=
ALLOW_LEGACY_ADMIN_HEADER=false
INTERNAL_API_SECRET=

# Admin password source (choose one)
# Option A: simple env password (dev/small setup)
ADMIN_PASSWORD=
ADMIN_PASSWORD_ROTATED_AT=
# Option B: Cloudflare worker password store (recommended)
CF_ADMIN_AUTH_URL=
CF_ADMIN_AUTH_TOKEN=

# R2 uploads (optional fallback provider)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# ImageKit uploads (recommended primary provider)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Optional: newsletter worker (EmailJS)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_GENERIC_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_STOCK_NOTIFICATION_TEMPLATE=

# Optional: forms Google webapp bridge
GOOGLE_FORMS_WEBAPP_URL=
GOOGLE_FORMS_SECRET=

# Optional: captcha for stock notifications API
TURNSTILE_SECRET_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Optional: links in stock email template
NEXT_PUBLIC_BASE_URL=

# Optional: trigger storefront revalidation after admin updates
STOREFRONT_REVALIDATE_URL=
STOREFRONT_REVALIDATE_SECRET=

# Optional: auto watermark product images on upload (default true)
ADMIN_IMAGE_WATERMARK_ENABLED=true
