# Client-side Firebase (from Firebase Web app settings)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Server-side Firebase Admin (required for live storefront data loading)
# Use a service account from Firebase Console -> Project settings -> Service accounts.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional alternative to the 3 vars above:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Storefront revalidate endpoint secret (used by admin app to refresh frontend after updates)
STOREFRONT_REVALIDATE_SECRET=

# Admin commerce analytics endpoint auth (GET /api/admin/commerce)
ADMIN_ANALYTICS_SECRET=

# Admin app URL — enables the /admin proxy in next.config.mjs.
# Local dev:    ADMIN_APP_URL=http://localhost:4000
# Production:   ADMIN_APP_URL=https://admin.merakithebrand.com
# Both /admin pages and /api/admin/* API calls are proxied to this URL.
ADMIN_APP_URL=
# NEXT_PUBLIC_ADMIN_APP_URL=   (alternative, also accepted)

# Optional admin-only override for order payment status updates (PATCH /api/orders)
ORDER_API_ADMIN_SECRET=

# ─── PesaPal Payments ──────────────────────────────────────────────────────────
# Production credentials from https://pay.pesapal.com/
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=

# Public-facing site URL — used to build PesaPal callback + IPN URLs
# e.g. https://merakithebrand.store  or  https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=

# ─── EmailJS (transactional emails — order confirmation) ─────────────────────
# Service account from https://dashboard.emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_titusac
# Template ID — create in EmailJS using scripts/emailjs-order-confirmation-template.html
EMAILJS_ORDER_TEMPLATE_ID=
# Public API key (EmailJS Dashboard → Account → API Keys)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Optional: Google Apps Script webapp for forms/newsletter sync
# Deploy your script as web app and use the /exec URL.
GOOGLE_FORMS_WEBAPP_URL=
GOOGLE_FORMS_SECRET=

# Optional: Google reCAPTCHA v2 for public forms
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
